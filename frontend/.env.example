# Same value as backend HR_SERVICE_API_KEY (sent as X-API-Key)
VITE_HR_API_KEY=

# Optional: full API origin. Leave unset in dev to use Vite proxy (/api -> Django).
# VITE_API_BASE_URL=http://127.0.0.1:8000

# PHP CRM should inject these values at runtime through window.__HR_CHATBOT_IDENTITY__.
# Env values are for local development only.
# VITE_COMPANY_ID=local-company
# VITE_EMPLOYEE_ID=local-employee

# Set to false to disable dev/preview proxy (then set VITE_API_BASE_URL and CORS on the API).
# VITE_USE_PROXY=false

# Speech-to-text (browser Web Speech — auto English / Bangla / Banglish)
# VITE_SPEECH_PROVIDER=webSpeech
# VITE_SPEECH_LANGUAGES=bn-BD,bn-IN,bn,en-IN,en-US
# VITE_SPEECH_AUTO_DETECT=true
# VITE_SPEECH_DEFAULT_MODE=bn
# VITE_SPEECH_FORCE_PRIMARY_LANGUAGE=false
# VITE_SPEECH_MAX_ALTERNATIVES=3
# VITE_WHISPER_MAX_RECORDING_MS=120000
