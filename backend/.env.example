# OpenAPI / Swagger UI (set false to hide /api/docs/, /api/redoc/, /api/schema/)
ENABLE_API_DOCS=true

# Django
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Auth: set a strong key for API requests (header: X-API-Key)
HR_SERVICE_API_KEY=local-dev-api-key-change-me

# LLM (OpenAI-compatible endpoint — works with OpenAI or Groq)
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=25
# Optional LLM tone polish for template messages (out-of-scope, expense wizard)
LLM_MESSAGE_POLISH=true

# Embeddings: openai = HTTP /v1/embeddings; local = sentence-transformers (no API key).
# Groq chat + local embed is a common setup.
EMBEDDING_BACKEND=openai
# EMBEDDING_BACKEND=local
LOCAL_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# LOCAL_EMBED_DEVICE=cuda
# When EMBEDDING_BACKEND=local and QDRANT_VECTOR_SIZE is unset, Django defaults to 384 for the model above.

# If chat is Groq but embeddings are OpenAI:
# EMBED_API_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=sk-...

OPENAI_EMBED_MODEL=text-embedding-3-small
# Optional explicit payload version; default is derived from backend/model/vector size.
# EMBEDDING_VERSION=openai:text-embedding-3-small:1536

# CRM
USE_MOCK=true
PHP_CRM_BASE_URL=https://your-php-crm.example.com
PHP_CRM_API_KEY=

TESSERACT_LANG=ben+eng

# Voice STT (Phase 2 — backend Whisper; optional if frontend uses Web Speech API only)
# OPENAI_WHISPER_API_KEY=
# OPENAI_WHISPER_API_BASE_URL=https://api.openai.com/v1
# OPENAI_WHISPER_MODEL=whisper-1
# VOICE_STT_PROVIDER=openai_whisper
# VOICE_MAX_UPLOAD_BYTES=10485760
# VOICE_MAX_DURATION_SECONDS=120



QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hr_policies_local
# RAG_SCORE_THRESHOLD=0.45
# After relaxed Qdrant pass, drop hits below this cosine score (0–1):
# RAG_MIN_SIMILARITY=0.3
# Verbose Qdrant payload logging (keys / first point):
# RAG_QUERY_DEBUG=false
# QDRANT_VECTOR_SIZE=1536
# For local embeddings (default model): use 384 or leave unset (auto 384).
# Qdrant HTTP timeouts (Docker on Windows can be slow on first write):
# QDRANT_TIMEOUT_SECONDS=300
# QDRANT_UPSERT_BATCH_SIZE=128
# QDRANT_UPSERT_WAIT=false
KB_RAG_ENABLED=true
# Optional override when the knowledge base has no matching chunk:
# KB_RAG_NOT_FOUND_MESSAGE=
